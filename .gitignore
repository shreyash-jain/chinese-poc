.DS_Store

# One lockfile only. Cloudflare Pages picks its package manager by which
# lockfile it finds, and prefers pnpm — a stray pnpm-lock.yaml made CI run
# `pnpm install --frozen-lockfile` against an out-of-date lockfile and fail.
# This project uses npm; package-lock.json is the source of truth.
pnpm-lock.yaml
yarn.lock
bun.lockb
branch_structure.json
temp_auto_push.bat
temp_interactive_push.bat
